{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "lifers: Bootstrap (deploy workspace + extensions)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tools/bootstrap_lifers.ps1"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    },
    {
      "label": "lifers: Bootstrap (offline, skip marketplace)",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/tools/bootstrap_lifers.ps1",
        "-SkipMarketplace"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "lifers: Integrated bootstrap only (prune + conditional materialize)",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/tools/run_integrated_bootstrap.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "lifers: Sync Cursor settings to VSCodium user-data",
      "type": "shell",
      "command": "python",
      "args": [
        "${workspaceFolder}/tools/sync_cursor_settings_to_vscodium.py"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
