# Example only — copy values into OS user environment (never commit real keys).
# Windows: System Properties → Environment Variables → User → New
#   Name: NVIDIA_API_KEY
#   Value: nvapi-... (from NGC / Integrate)
# Linux/Kali: echo 'export NVIDIA_API_KEY=nvapi-...' >> ~/.profile && source ~/.profile
#
# Bridge reads the same variable; optional overrides:
# LIFERS_CHAT_URL=https://integrate.api.nvidia.com/v1/chat/completions
# LIFERS_CHAT_MODEL=meta/llama-3.1-8b-instruct
# LIFERS_LOCAL_FALLBACK=0
