{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Lifers: 本地智脑对话 (Agent)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["scripts/run_agent.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "LIFERS_ROOT": "${workspaceFolder}",
          "PYTHONUTF8": "1",
          "SANDBOX": "1",
          "MODEL": "transformer"
        }
      },
      "presentation": { "reveal": "always", "panel": "new", "focus": true },
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "Lifers: 训练 Markov（日常对话语料风格）",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["scripts/train_weights.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "LIFERS_ROOT": "${workspaceFolder}",
          "PYTHONUTF8": "1",
          "SANDBOX": "1",
          "MODEL": "markov"
        }
      },
      "presentation": { "reveal": "always", "panel": "new" },
      "problemMatcher": []
    },
    {
      "label": "Lifers: 训练 lifers_transformer（本地流水线）",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["scripts/train_transformer_weights.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "LIFERS_ROOT": "${workspaceFolder}",
          "PYTHONUTF8": "1",
          "SANDBOX": "1",
          "MODEL": "transformer"
        }
      },
      "presentation": { "reveal": "always", "panel": "new" },
      "problemMatcher": []
    },
    {
      "label": "Lifers: 完整流水线（训练+评测+仿真闸）",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["scripts/run_pipeline.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "LIFERS_ROOT": "${workspaceFolder}",
          "PYTHONUTF8": "1",
          "SANDBOX": "1",
          "MODEL": "transformer"
        }
      },
      "presentation": { "reveal": "always", "panel": "new" },
      "problemMatcher": []
    },
    {
      "label": "Lifers: 列出全部工具 JSON",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["scripts/list_tools.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "LIFERS_ROOT": "${workspaceFolder}", "PYTHONUTF8": "1" }
      },
      "presentation": { "reveal": "always", "panel": "new" },
      "problemMatcher": []
    },
    {
      "label": "Lifers: Agent（关闭沙盒，允许真实联网与高风险路径需自担）",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["scripts/run_agent.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "LIFERS_ROOT": "${workspaceFolder}",
          "PYTHONUTF8": "1",
          "SANDBOX": "0",
          "MODEL": "transformer"
        }
      },
      "presentation": { "reveal": "always", "panel": "new" },
      "problemMatcher": []
    },
    {
      "label": "Lifers: Sync Cursor→VSCodium 工作区设置",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["${workspaceFolder}/../tools/sync_cursor_settings_to_vscodium.py"],
      "options": { "cwd": "${workspaceFolder}/.." },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Lifers: 对照上游 OpenClaw release 更新锚点",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["scripts/sync_openclaw_release.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "PYTHONUTF8": "1" }
      },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Lifers: 验证 stack 配置",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["scripts/lifers_verify_config.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "LIFERS_ROOT": "${workspaceFolder}", "PYTHONUTF8": "1" }
      },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Lifers: 安装 Agents UI（含校验）",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/../tools/install_agents_extension.ps1"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Lifers: 自研 GUI 宿主 (run_lifers_gui_host)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["scripts/run_lifers_gui_host.py", "--no-browser"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}",
          "PYTHONUTF8": "1",
          "LIFERS_ROOT": "${workspaceFolder}"
        }
      },
      "presentation": { "reveal": "always", "panel": "new" },
      "problemMatcher": []
    },
    {
      "label": "Lifers: 聚合自检 (unittest + full_system_check)",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["scripts/lifers_run_all_checks.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}",
          "PYTHONUTF8": "1",
          "LIFERS_ROOT": "${workspaceFolder}"
        }
      },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Lifers: 离线下载 Monaco vendor",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/Scripts/python.exe",
      "args": ["tools/lifers_gui_host/fetch_offline_monaco.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "PYTHONPATH": "${workspaceFolder}", "PYTHONUTF8": "1" }
      },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
