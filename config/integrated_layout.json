{
  "_comment": "Integrated layout config — referenced in README as merge/co-op config.",
  "version": "1.0.0",
  "layout": "integrated",

  "workspace_outputs": ["lifers.code-workspace"],

  "roots": [
    { "name": "rs0", "path": "./rs0" },
    { "name": "lifers", "path": "." },
    { "name": "lifers", "path": "./lifers" }
  ],

  "workspace_settings": {
    "lifers.bridgeTimeoutMs": 120000,
    "lifers.edgeGenerateTimeoutSec": 110
  },

  "workspaces": [
    {
      "id": "lifers",
      "path": "./lifers",
      "role": "primary",
      "description": "Python AI brain — inference, agents, NPC"
    },
    {
      "id": "third_party_openclaw",
      "path": "./third_party/openclaw",
      "role": "reference",
      "description": "OpenClaw upstream — audit only, not called at runtime"
    },
    {
      "id": "third_party_claw_code_rust",
      "path": "./third_party/claw_code_rust",
      "role": "reference",
      "description": "Kali claw-code/rust vendor — audit only"
    }
  ],

  "merge_policy": {
    "authority": "lifers",
    "openclaw_merge": "audit_only",
    "claw_code_rust_merge": "audit_only",
    "cloud_api": "disabled_by_default"
  },

  "runtime_entry": {
    "agent":   "lifers/scripts/run_agent.py",
    "bridge":  "lifers/scripts/agent_bridge.py",
    "stack":   "lifers/config/stack.json"
  },

  "npc": {
    "persona_dir":    "lifers/config/personas",
    "memory_db":      "lifers/memory/lifers.sqlite3",
    "state_persist":  true
  }
}
