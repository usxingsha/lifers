# ============================================================================
# Lifers Environment Variables Reference
# Copy to .env or config/secrets.env and adjust as needed.
# All variables are optional unless marked [REQUIRED].
# ============================================================================

# ---- Core ----
# LIFERS_ROOT         Project root directory (auto-detected from file location)
# MODEL               Brain backend: lifers | transformer | markov (default: lifers)
# SANDBOX             Enable sandbox mode (default: 1)
# LIFERS_RUNTIME      Runtime role: brain | robot | human_sim (default: auto)

# ---- Remote Inference (default: local-only) ----
# LIFERS_ALLOW_REMOTE_INFER  Master switch to enable remote API (default: unset)
# LIFERS_FORCE_LOCAL_ONLY    Force local-only, disable remote (default: unset)
# LIFERS_REMOTE_CHAT         Enable remote chat fallback (default: unset)
# LIFERS_CHAT_URL            Remote API endpoint (default: https://integrate.api.nvidia.com/v1/chat/completions)
# LIFERS_CHAT_API_KEY        API key for remote chat
# LIFERS_CHAT_API_KEY_ENV    Env var name to read API key from (e.g., NVIDIA_API_KEY)
# LIFERS_CHAT_MODEL          Model name for remote API (default: meta/llama-3.1-8b-instruct)
# LIFERS_CHAT_MAX_TOKENS     Max tokens for remote generation (default: 1024)
# LIFERS_CHAT_TIMEOUT_SEC    Timeout for remote API calls (default: 120)

# ---- Taskflow Pipeline ----
# LIFERS_TASKFLOW            Use full taskflow orchestration (default: 1)
# LIFERS_AGENTS_UI_BRIDGE    Set by VSCodium extension (default: unset)

# ---- Quick Chat (CHAT_QUICK path) ----
# LIFERS_QUICK_FAST              Trivial ASCII shortcuts (default: 0)
# LIFERS_QUICK_SKIP_KB           Skip knowledge base retrieval (default: 0)
# LIFERS_QUICK_WEB               Auto web search fallback (default: 0)
# LIFERS_QUICK_GENERATE_TIMEOUT_SEC  Generation timeout (default: varies)
# LIFERS_QUICK_CHAT_LEARN        Write CHAT_QUICK to longterm memory (default: 0)
# LIFERS_QUICK_TIME_FOOTER       Append generation timestamp (default: 0)
# LIFERS_QUICK_SESSION_CONTEXT_CHARS  Max chars for session context
# LIFERS_QUICK_PACK_MAX_CHARS    Max chars for full prompt pack
# LIFERS_QUICK_META_USE_LOCAL_BRAIN  Use local brain for meta queries (default: 1)
# LIFERS_QUICK_WEB_RESPECT_HOST  Respect host's LIFERS_QUICK_WEB setting (default: 0)

# ---- Memory & Learning ----
# LIFERS_STEWARD            Enable memory pruning (default: 1)
# LIFERS_CONTEXT_MAX_FILES  Max context files per turn (default: 32)

# ---- Self-Heal & Self-Code ----
# LIFERS_SELF_HEAL          Auto-repair stack.json (default: 1)
# LIFERS_SELF_CODE_QUEUE    Self-code queue processing (default: 1)

# ---- Health & Diagnostics ----
# LIFERS_SKIP_HEALTH_CHECK  Skip startup health diagnostic (default: unset)
# LIFERS_DAILY_HEALTH_AUTO_REMEDIATE  Auto-fix in daily health check
# LIFERS_FULL_CHECK_BRIDGE  Run bridge tests during full check (default: 1)
# LIFERS_FULL_CHECK_NETWORK Run network tests during full check (default: 0)

# ---- Training ----
# LIFERS_TRAIN_CONTROL      Training control: run | pause | stop
# LIFERS_TRAIN_STATUS_BRAIN_ROOT  Brain root for training status reporting
# LIFERS_DEEP_MIN_LAYERS    Minimum layers for deep transformer escalate
# LIFERS_TEMP               Temperature override for deep transformer
# LIFERS_USE_NUMPY          Use numpy for weight operations (default: unset)

# ---- HTTP Gate ----
# LIFERS_HTTP_DIRECT        Bypass HTTP safety restrictions (default: unset)
# LIFERS_PLUGINS            Enable plugin system (default: unset)

# ---- Realtime Context ----
# LIFERS_GEO_LABEL               Geohash or location label
# LIFERS_REALTIME_GEO_QUICK      Quick geo lookup enabled
# LIFERS_REALTIME_GEO_CACHE_SEC  Geo cache TTL in seconds

# ---- OpenClaw Integration ----
# LIFERS_OPENCLAW_ENABLED
# LIFERS_OPENCLAW_PROJECT_DIR

# ---- Sim / Robot Commands ----
# SIM_EXEC_CMD       Simulation execution command
# ROBOT_SENSE_CMD    Robot sense command
# ROBOT_ACT_CMD      Robot act command

# ---- BLAS Thread Control ----
# OMP_NUM_THREADS
# OPENBLAS_NUM_THREADS
# MKL_NUM_THREADS

# ---- Development ----
# LIFERS_CHAT_VERBOSE       Verbose output for lifers chat CLI
# LIFERS_PROGRESS_ASCII     Force ASCII progress bars
# PYTHONUTF8                Set to 1 for UTF-8 mode (recommended)
