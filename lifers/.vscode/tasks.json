{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Lifers: Agent 对话",
      "type": "shell",
      "command": "python3",
      "args": ["scripts/run_agent.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "LIFERS_ROOT": "${workspaceFolder}", "PYTHONUTF8": "1", "SANDBOX": "1", "MODEL": "transformer" }
      },
      "presentation": { "reveal": "always", "panel": "new", "focus": true },
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "label": "Lifers: 训练 Deep Transformer",
      "type": "shell",
      "command": "python3",
      "args": ["lifers/scripts/train_deep_escalate.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "LIFERS_ROOT": "${workspaceFolder}", "PYTHONUNBUFFERED": "1", "LIFERS_ESCALATE_UNLIMITED": "1" }
      },
      "presentation": { "reveal": "always", "panel": "new" }
    },
    {
      "label": "Lifers: CLI 终端",
      "type": "shell",
      "command": "lifers",
      "args": [],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "new", "focus": true }
    },
    {
      "label": "Lifers: 查看训练状态",
      "type": "shell",
      "command": "lifers",
      "args": ["stats"],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Lifers: 查看配置",
      "type": "shell",
      "command": "lifers",
      "args": ["config"],
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "Lifers: 聚合自检",
      "type": "shell",
      "command": "python3",
      "args": ["scripts/lifers_run_all_checks.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": { "PYTHONPATH": "${workspaceFolder}", "PYTHONUTF8": "1", "LIFERS_ROOT": "${workspaceFolder}" }
      },
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ]
}
