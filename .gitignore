# 联运布局（须跟踪）：config/integrated_layout.json — 勿添加误伤整条 config/ 的忽略规则

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/

# Weights and training checkpoints (large binary, fetched separately)
*.npz

# Optional NTFS junction to sibling ../lifers — created by tools/link_lifers_app.ps1
# Git sees this as a file (not directory), pattern /lifers matches both.
# Use ! prefix to un-ignore the directory.
/lifers
!/lifers/

# 便携壳/内嵌 VS Code 体积巨大，不进入 Git（本地可选解压）
/shell/

# 打包产物（Kali 推送包等）；需要时在本地重新运行 package_rs_for_kali.ps1
/lifers/dist/*.tar.gz
/lifers/dist/*.tgz

# 本地二进制壳（可选）
/LifersShell.exe

# 大权重：从 Kali 拉取，勿入版本库（见 lifers/scripts/sync_weights_from_kali.ps1）
/lifers/weights/lifers_transformer.json
/lifers/weights/.train_status.json
/lifers/extensions/lifers-agents-ui/media/phoenix-void.png

# 每日 AI 健康报告（本地/计划任务生成）
/lifers/state/daily_health/

# 会话侧本地状态
/lifers/.lifers/

# 运行期日志与本地记忆库（勿入库）
/lifers/logs/
/lifers/memory/*.sqlite3

# 本地 data/（Cursor 状态、扩展缓存、用户数据等）不进入版本库
/data/

# Local workspace overlay (optional)
/config/workspace_custom.json

# OpenClaw 通过 git submodule 跟踪（见 .gitmodules）；勿忽略 third_party/openclaw。
# 亦可用 scripts/vendor_openclaw_reference.ps1 浅克隆；纳入仓库时请改为 submodule 或删除目录后 git submodule add。

# claw-code/rust vendor: local cargo output must not be committed
/third_party/claw_code_rust/target/

# 可选：本机临时对照检出目录（勿默认入库）
/third_party/_refs/
