{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Lifers: Debug run_agent.py",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/run_agent.py",
      "cwd": "${workspaceFolder}",
      "env": {
        "LIFERS_ROOT": "${workspaceFolder}",
        "PYTHONUTF8": "1",
        "SANDBOX": "1",
        "MODEL": "transformer"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Lifers: Debug train_deep_escalate",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/train_deep_escalate.py",
      "cwd": "${workspaceFolder}",
      "env": {
        "LIFERS_ROOT": "${workspaceFolder}",
        "PYTHONUNBUFFERED": "1",
        "LIFERS_ESCALATE_UNLIMITED": "1"
      },
      "console": "integratedTerminal"
    },
    {
      "name": "Lifers: Attach to running process",
      "type": "python",
      "request": "attach",
      "connect": { "host": "localhost", "port": 5678 }
    }
  ]
}
