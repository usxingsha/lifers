#!/usr/bin/env bash
# lifers — local AI terminal assistant (Linux launcher)
# Usage: lifers [chat|ask|code|think|stats|test] [...]
# Install: ln -s "$(pwd)/scripts/lifers" /usr/local/bin/lifers
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(dirname "$SCRIPT_DIR")"
export PYTHONPATH="${PYTHONPATH:-}:${ROOT}"
export LIFERS_ROOT="${ROOT}"
exec python3 "${SCRIPT_DIR}/lifers_chat.py" "$@"
